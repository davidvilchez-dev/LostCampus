{
  "properties": [
    {
      "name": "cloudinary.cloud-name",
      "type": "java.lang.String",
      "description": "Cloud Name for Cloudinary configuration."
    },
    {
      "name": "cloudinary.api-key",
      "type": "java.lang.String",
      "description": "API Key for Cloudinary configuration."
    },
    {
      "name": "cloudinary.api-secret",
      "type": "java.lang.String",
      "description": "API Secret for Cloudinary configuration."
    },
    {
      "name": "application.security.jwt.secret-key",
      "type": "java.lang.String",
      "description": "Secret key used for JWT signing and validation."
    },
    {
      "name": "application.security.jwt.expiration",
      "type": "java.lang.Long",
      "description": "JWT expiration time in milliseconds."
    }
  ]
}
